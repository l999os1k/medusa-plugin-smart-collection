		"@medusajs/medusa": "^2.14.0",
		"@medusajs/types": "^2.14.0",
		"@medusajs/ui": "^4.1.0",
		"@tanstack/react-query": "^5.64.0",
		"react": "^18.3.1 || ^19.0.0",
		"react-dom": "^18.3.1 || ^19.0.0"
	},
