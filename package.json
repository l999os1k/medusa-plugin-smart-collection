		"@medusajs/test-utils": "2.14.2",
		"@medusajs/types": "2.14.2",
		"@medusajs/ui": "4.1.8",
		"@swc/core": "^1.7.28",
		"@swc/jest": "^0.2.36",
		"@tanstack/react-query": "5.64.2",
		"@types/jest": "^29.5.13",
		"@types/node": "^20.12.11",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"jest": "^29.7.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"ts-node": "^10.9.2",
		"typescript": "^5.7.3"
	},
	"peerDependencies": {
		"@medusajs/admin-sdk": "^2.14.0",
