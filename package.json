{
	"name": "medusa-plugin-smart-collection",
	"version": "0.1.1",
	"description": "Metadata-based smart product collections for Medusa v2.",
	"author": "",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/l999os1k/medusa-plugin-smart-collection.git"
	},
	"bugs": {
		"url": "https://github.com/l999os1k/medusa-plugin-smart-collection/issues"
	},
	"homepage": "https://github.com/l999os1k/medusa-plugin-smart-collection#readme",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"files": [
		".medusa/server",
		"README.md",
		"LICENSE"
	],
	"exports": {
		"./package.json": "./package.json",
		"./workflows": {
			"import": "./.medusa/server/src/workflows/index.js",
			"types": "./.medusa/server/src/workflows/index.d.ts",
			"require": "./.medusa/server/src/workflows/index.js"
		},
		"./admin": {
			"import": "./.medusa/server/src/admin/index.mjs",
			"require": "./.medusa/server/src/admin/index.js",
			"default": "./.medusa/server/src/admin/index.js"
		},
		"./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
		"./*": "./.medusa/server/src/*.js"
	},
	"keywords": [
		"medusa",
		"medusa-v2",
		"medusa-plugin",
		"smart-collections",
		"product-collections",
		"ecommerce",
		"typescript"
	],
	"scripts": {
		"build": "medusa plugin:build",
		"dev": "medusa plugin:develop",
		"typecheck": "tsc --noEmit",
		"test": "jest --silent --runInBand --forceExit"
	},
	"devDependencies": {
		"@medusajs/admin-sdk": "2.14.2",
